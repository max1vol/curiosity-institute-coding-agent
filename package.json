{
  "name": "curiosity-institute-coding-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SvelteKit chat app for the Curiosity Institute, wired to GPT-5.4 xhigh.",
  "scripts": {
    "dev": "vite dev --host 127.0.0.1 --port 3000",
